#!/bin/bash
#
# TJBot Launcher - Generic launcher for all TJBot operations
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to show usage
show_usage() {
    echo "TJBot Launcher"
    echo ""
    echo "Usage:"
    echo "  tjbot bootstrap           Run the bootstrap setup script"
    echo "  tjbot config [args]       Configure TJBot credentials and settings"
    echo "  tjbot run                 List available recipes"
    echo "  tjbot run <recipe>        Run a specific recipe"
    echo ""
}

# Function to list recipes
list_recipes() {
    echo -e "${BLUE}Available TJBot Recipes:${NC}"
    echo ""

    if [ ! -d "$SCRIPT_DIR/recipes" ]; then
        echo -e "${RED}Error: recipes directory not found${NC}"
        exit 1
    fi

    for recipe_dir in "$SCRIPT_DIR/recipes"/*; do
        if [ -d "$recipe_dir" ]; then
            recipe_name=$(basename "$recipe_dir")

            # Determine recipe type
            if [ -f "$recipe_dir/package.json" ]; then
                recipe_type="${GREEN}[JavaScript]${NC}"
            elif [ -f "$recipe_dir/pyproject.toml" ]; then
                recipe_type="${YELLOW}[Python]${NC}"
            else
                recipe_type="${RED}[Unknown]${NC}"
            fi

            echo -e "  - $recipe_name $recipe_type"
        fi
    done
    echo ""
    echo "Run a recipe with: tjbot run <recipe>"
}

# Function to run a recipe
run_recipe() {
    local recipe_name="$1"
    local recipe_dir="$SCRIPT_DIR/recipes/$recipe_name"

    if [ ! -d "$recipe_dir" ]; then
        echo -e "${RED}Error: Recipe '$recipe_name' not found${NC}"
        echo ""
        echo "Available recipes:"
        list_recipes
        exit 1
    fi

    # Detect recipe type and run accordingly
    if [ -f "$recipe_dir/package.json" ]; then
        echo -e "${GREEN}Running JavaScript recipe: $recipe_name${NC}"
        cd "$recipe_dir" || exit 1

        # Check if npm is installed
        if ! command -v npm &> /dev/null; then
            echo -e "${RED}Error: npm is not installed${NC}"
            exit 1
        fi

        # Install dependencies if node_modules doesn't exist
        if [ ! -d "node_modules" ]; then
            echo -e "${YELLOW}Installing dependencies...${NC}"
            npm install
        fi

        npm start

    elif [ -f "$recipe_dir/pyproject.toml" ]; then
        echo -e "${YELLOW}Running Python recipe: $recipe_name${NC}"
        cd "$recipe_dir" || exit 1

        # Check if uv is installed
        if ! command -v uv &> /dev/null; then
            echo -e "${RED}Error: uv is not installed${NC}"
            echo ""
            echo "Install uv with:"
            echo "  curl -LsSf https://astral.sh/uv/install.sh | sh"
            exit 1
        fi

        uv run

    else
        echo -e "${RED}Error: Unable to determine recipe type for '$recipe_name'${NC}"
        echo "Recipe must contain either package.json (JavaScript) or pyproject.toml (Python)"
        exit 1
    fi
}

# Main command routing
case "$1" in
    bootstrap)
        echo -e "${GREEN}Running TJBot bootstrap...${NC}"
        cd "$SCRIPT_DIR/bootstrap" || exit 1
        exec $SHELL bootstrap.sh
        ;;

    config)
        shift
        cd "$SCRIPT_DIR/config" || exit 1

        # Check if uv is installed
        if ! command -v uv &> /dev/null; then
            echo -e "${RED}Error: uv is not installed${NC}"
            echo ""
            echo "Install uv with:"
            echo "  curl -LsSf https://astral.sh/uv/install.sh | sh"
            exit 1
        fi

        exec uv run config.py "$@"
        ;;

    run)
        if [ -z "$2" ]; then
            list_recipes
        else
            run_recipe "$2"
        fi
        ;;

    "")
        show_usage
        ;;

    *)
        echo -e "${RED}Error: Unknown command '$1'${NC}"
        echo ""
        show_usage
        exit 1
        ;;
esac
