# Function to generate language starter files
write_language_starters() {
    local recipe_dir="$1"
    local recipe_name="$2"
    local description="$3"
    local author="$4"
    local license="$5"
    local language="$6"
    local listen="$7"
    local see="$8"
    local shine="$9"
    local speak="${10}"
    local wave="${11}"

    if [ "$language" = "typescript" ]; then
        # Build hardware config based on capabilities
        local hardware_lines=""
        [ "$listen" = "true" ] && hardware_lines+="        microphone: true,\n"
        [ "$see" = "true" ] && hardware_lines+="        camera: true,\n"
        [ "$shine" = "true" ] && hardware_lines+="        led: true,\n"
        [ "$speak" = "true" ] && hardware_lines+="        speaker: true,\n"
        [ "$wave" = "true" ] && hardware_lines+="        servo: true,\n"

        # Remove trailing comma from last line
        hardware_lines=$(echo -e "$hardware_lines" | sed '$ s/,$//')

        local file_ext="ts"
        local start_script="tsx index.ts"
        local recipe_slug
        recipe_slug="$(basename "$recipe_dir")"

        cat > "$recipe_dir/index.$file_ext" << EOF
/**
 * $recipe_name
 * Author: $author
 */

import TJBot from 'tjbot';

const tj = await TJBot.getInstance().initialize({
    hardware: {
${hardware_lines}
    }
});

// Add your recipe code here!

EOF

        cat > "$recipe_dir/package.json" << EOF
{
    "name": "$recipe_slug",
    "version": "1.0.0",
    "description": "$description",
    "license": "$license",
    "author": "$author",
    "type": "module",
    "main": "index.$file_ext",
    "scripts": {
        "start": "tsx index.ts",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "test": "echo \"Error: no test specified\" && exit 1"
    }
}
EOF

        echo -e "${BLUE}Installing dependencies...${NC}"
        (cd "$recipe_dir" && npm install tjbot)

        if [ "$language" = "typescript" ]; then
            (cd "$recipe_dir" && npm install --save-dev @eslint/js eslint globals tsx typescript typescript-eslint)
        fi

        if [ "$language" = "typescript" ]; then
            cat > "$recipe_dir/tsconfig.json" << 'EOF'
{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"]
}
EOF
        fi
    else
        cat > "$recipe_dir/main.py" << 'EOF'
def main():
    print("Hello from TJBot recipe!")


if __name__ == "__main__":
    main()
EOF

        cat > "$recipe_dir/pyproject.toml" << EOF
[project]
name = "$recipe_slug"
version = "1.0.0"
description = "A TJBot recipe"
requires-python = ">=3.11"
dependencies = []

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
EOF
    fi
}

# Function to create a recipe scaffold
create_recipe() {
    local recipe_folder="$1"
    local recipe_name
    local description
    local author
    local license
    local language
    local recipe_dir
    local listen
    local see
    local shine
    local speak
    local wave

    if [ -z "$recipe_folder" ]; then
        echo -e "${RED}Error: Recipe name required${NC}"
        echo "Usage: tjbot create <recipe-name>"
        exit 1
    fi

    # Strip any directory prefix (e.g. "recipes/test-recipe" -> "test-recipe")
    recipe_folder="$(basename "$recipe_folder")"
    recipe_dir="$TJBOT_ROOT/recipes/$recipe_folder"
    if [ -e "$recipe_dir" ]; then
        echo -e "${RED}Error: Recipe already exists at $recipe_dir${NC}"
        exit 1
    fi

    echo -e "${BLUE}Create TJBot recipe${NC}"
    echo ""

    read -r -p "Display name [$recipe_folder]: " recipe_name
    recipe_name="${recipe_name:-$recipe_folder}"

    read -r -p "Description: " description
    if [ -z "$description" ]; then
        description="TODO: Add description"
    fi

    read -r -p "Author [TJBot Contributor]: " author
    if [ -z "$author" ]; then
        author="TJBot Contributor"
    fi

    read -r -p "License [Apache-2.0]: " license
    if [ -z "$license" ]; then
        license="Apache-2.0"
    fi

    read -r -p "Language (python/py or typescript/ts): " language
    case "$language" in
        python|py)
            language="python"
            ;;
        typescript|ts)
            language="typescript"
            ;;
        *)
            echo -e "${RED}Error: Language must be 'python', 'py', 'typescript', or 'ts'${NC}"
            exit 1
            ;;
    esac

    echo ""
    echo "Required capabilities:"
    listen=$(prompt_yes_no "- listen (microphone + STT) (y/n) [n]: " "n")
    see=$(prompt_yes_no "- see (camera + vision) (y/n) [n]: " "n")
    shine=$(prompt_yes_no "- shine (LED) (y/n) [n]: " "n")
    speak=$(prompt_yes_no "- speak (speaker + TTS) (y/n) [n]: " "n")
    wave=$(prompt_yes_no "- wave (servo) (y/n) [n]: " "n")

    mkdir -p "$recipe_dir"

    write_recipe_toml "$recipe_dir" "$recipe_name" "$description" "$author" "$license"
    write_mise_toml "$recipe_dir" "$language"
    write_language_starters "$recipe_dir" "$recipe_name" "$description" "$author" "$license" "$language" "$listen" "$see" "$shine" "$speak" "$wave"
    write_recipe_readme "$recipe_dir" "$recipe_name" "$description" "$recipe_folder" "$license" "$listen" "$see" "$shine" "$speak" "$wave" "$language"

    echo ""
    echo -e "${GREEN}Created recipe at: $recipe_dir${NC}"
}

# Function to run a hardware test
test_hardware() {
    local hardware="$1"
    local valid_hardware=("camera" "led" "microphone" "servo" "speaker" "stt" "tts")

    if [ -z "$hardware" ]; then
        echo -e "${BLUE}Available hardware tests:${NC}"
        echo ""
        for h in "${valid_hardware[@]}"; do
            echo "  - $h"
        done
        echo ""
        echo "Run a test with: tjbot test <hardware>"
        return 0
    fi

    # Validate hardware argument
    local valid=false
    for h in "${valid_hardware[@]}"; do
        if [ "$hardware" = "$h" ]; then
            valid=true
            break
        fi
    done

    if [ "$valid" = "false" ]; then
        echo -e "${RED}Error: Unknown hardware '$hardware'${NC}"
        echo ""
        echo -e "${BLUE}Available hardware tests:${NC}"
        echo ""
        for h in "${valid_hardware[@]}"; do
            echo "  - $h"
        done
        echo ""
        return 1
    fi

    # Check if mise is installed
    if ! command -v mise &> /dev/null; then
        echo -e "${RED}Error: mise is not installed${NC}"
        echo ""
        echo "Install mise with:"
        echo "  curl https://mise.run | sh"
        return 1
    fi

    # Run the test from tjbot/tests directory via mise tasks
    echo -e "${GREEN}Running hardware test: $hardware${NC}"
    cd "$TJBOT_ROOT/tests" || return 1

    # test-* tasks depend on install in tests/mise.toml
    mise run "test-$hardware"
}

# Function to run a recipe
run_recipe() {
    local recipe_name="$1"
    local recipe_dir=""

    # Check if mise is installed first
    if ! command -v mise &> /dev/null; then
        echo -e "${RED}Error: mise is not installed${NC}"
        echo ""
        echo "Install mise with:"
        echo "  curl https://mise.run | sh"
        exit 1
    fi

    # First, try to treat the input as a path
    if [ "$recipe_name" = "." ]; then
        recipe_dir="$PWD"
    elif [ -d "$recipe_name" ]; then
        # Convert to absolute path
        recipe_dir="$(cd "$recipe_name" && pwd)"
    fi

    # If we found a valid directory path, try to validate and run it
    if [ -n "$recipe_dir" ] && validate_recipe_dir "$recipe_dir"; then
        echo -e "${GREEN}Running recipe: $recipe_name${NC}"
        cd "$recipe_dir" || exit 1
        mise run start
        return 0
    fi

    # Try as a built-in recipe name
    recipe_dir="$TJBOT_ROOT/recipes/$recipe_name"
    if [ -d "$recipe_dir" ] && validate_recipe_dir "$recipe_dir"; then
        echo -e "${GREEN}Running recipe: $recipe_name${NC}"
        cd "$recipe_dir" || exit 1
        mise run start
        return 0
    fi

    # Neither a valid path nor a built-in recipe
    echo -e "${RED}Error: No recipe found at '$recipe_name'${NC}"
    echo ""
    echo "Available built-in recipes:"
    list_recipes
    exit 1
}

# Main command routing
case "$1" in
    bootstrap)
        echo -e "${GREEN}Running TJBot bootstrap...${NC}"
        cd "$TJBOT_ROOT/bin" || exit 1
        sudo "$SHELL" ./bootstrap
        ;;

    config)
        shift
        cd "$TJBOT_ROOT/config" || exit 1

        # Check if uv is installed
        if ! command -v uv &> /dev/null; then
            echo -e "${RED}Error: uv is not installed${NC}"
            echo ""
            echo "Install uv with:"
            echo "  curl -LsSf https://astral.sh/uv/install.sh | sh"
            exit 1
        fi

        # Plain `tjbot config` with no subcommand defaults to the editor.
        if [ $# -eq 0 ]; then
            exec uv run config.py edit
        fi

        exec uv run config.py "$@"
        ;;

    test)
        test_hardware "$2"
        ;;

    run)
        if [ -z "$2" ]; then
            list_recipes
        else
            run_recipe "$2"
        fi
        ;;

    create)
        create_recipe "$2"
        ;;

    update)
        do_update "$2"
        ;;

    check-updates)
        echo -e "${BLUE}Checking for TJBot updates...${NC}"
        current_version=$(get_current_version)
        latest_version=$(check_latest_release)

        if [ "$latest_version" = "ERROR_NO_NETWORK" ]; then
            echo -e "${RED}Error: Could not connect to GitHub${NC}"
            echo "Please check your internet connection and try again."
            exit 1
        fi

        if [ "$latest_version" = "ERROR_NO_RELEASES" ]; then
            echo -e "${YELLOW}No releases available yet${NC}"
            echo "Check back later for official TJBot releases."
            exit 0
        fi

        echo "Current version: $current_version"
        echo "Latest version:  $latest_version"
        echo ""

        if [ "$current_version" = "$latest_version" ]; then
            echo -e "${GREEN}You are already running the latest version!${NC}"
        else
            echo -e "${YELLOW}A new version is available.${NC}"
            read -p "Would you like to update? (y/n) " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                do_update "$latest_version"
            fi
        fi
        ;;

    "")
        show_usage
        ;;

    *)
        echo -e "${RED}Error: Unknown command '$1'${NC}"
        echo ""
        show_usage
        exit 1
        ;;
esac
