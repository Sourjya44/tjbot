#!/bin/bash
#
# TJBot Launcher - Generic launcher for all TJBot operations
#

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Get the script's real location (resolve symlinks, handle PATH invocation)
# The parent of bin/ is always the tjbot directory
TJBOT_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
TJBOT_REPO="$HOME/.tjbot/tjbot"
TJBOT_STATE_DIR="$HOME/.tjbot"
LAST_UPDATE_CHECK_FILE="$TJBOT_STATE_DIR/.last-update-check"
GITHUB_API_ENDPOINT="https://api.github.com/repos/tjbot-ce/tjbot/releases/latest"
UPDATE_CHECK_INTERVAL=$((30 * 24 * 60 * 60)) # 30 days in seconds

# Determine if we're running the installed version or dev version
IS_INSTALLED=false
if [ "$TJBOT_ROOT" = "$TJBOT_REPO" ]; then
    IS_INSTALLED=true
else
    echo -e "${GREEN}Running development version of TJBot${NC}"
fi

# Function to show usage
show_usage() {
    echo "TJBot Launcher"
    echo ""
    echo "Usage:"
    echo "  tjbot bootstrap           Run the bootstrap setup script"
    echo "  tjbot config [args]       Configure TJBot credentials and settings"
    echo "  tjbot run                 List available recipes"
    echo "  tjbot run <recipe>        Run a specific recipe"
    echo "  tjbot create [recipe-name] Create a new recipe"
    echo "  tjbot update [tag]        Update TJBot to latest release (or specific tag)"
    echo "  tjbot check-updates       Check for available updates"
    echo ""
}

# Function to get current version from git tag
get_current_version() {
    if [ ! -d "$TJBOT_REPO/.git" ]; then
        echo "unknown"
        return 1
    fi

    local tag
    tag=$(git -C "$TJBOT_REPO" describe --tags --abbrev=0 2>/dev/null)
    if [ -z "$tag" ]; then
        # Fallback to short commit hash if no tags exist
        git -C "$TJBOT_REPO" rev-parse --short HEAD 2>/dev/null || echo "unknown"
    else
        echo "$tag"
    fi
}

# Function to get latest release from GitHub
check_latest_release() {
    local response
    local tag_name

    # Use curl to fetch latest release info from GitHub API
    # Add timeout to prevent hanging
    response=$(curl -s --max-time 5 "$GITHUB_API_ENDPOINT" 2>/dev/null)

    if [ -z "$response" ]; then
        return 1
    fi

    # Extract tag_name using grep and sed (basic JSON parsing)
    tag_name=$(echo "$response" | grep -o '"tag_name":"[^"]*"' | head -1 | cut -d'"' -f4)

    if [ -z "$tag_name" ]; then
        return 1
    fi

    echo "$tag_name"
}

# Function to check if we should perform an update check
should_check_for_updates() {
    # Only check for updates if running the installed version
    if [ "$IS_INSTALLED" != "true" ]; then
        return 1
    fi

    # Don't check in CI/non-interactive environments
    if [ ! -t 1 ] || [ -n "$CI" ] || [ -n "$TJBOT_SKIP_UPDATES" ]; then
        return 1
    fi

    # Don't check if repo doesn't exist
    if [ ! -d "$TJBOT_REPO/.git" ]; then
        return 1
    fi

    # Create state directory if it doesn't exist
    mkdir -p "$TJBOT_STATE_DIR"

    # If file doesn't exist, we should check
    if [ ! -f "$LAST_UPDATE_CHECK_FILE" ]; then
        return 0
    fi

    # Check if enough time has passed
    local last_check
    local current_time
    local time_diff

    last_check=$(cat "$LAST_UPDATE_CHECK_FILE" 2>/dev/null)
    current_time=$(date +%s)
    time_diff=$((current_time - last_check))

    if [ "$time_diff" -ge "$UPDATE_CHECK_INTERVAL" ]; then
        return 0
    fi

    return 1
}

# Function to update the last check timestamp
update_last_check_timestamp() {
    mkdir -p "$TJBOT_STATE_DIR"
    date +%s > "$LAST_UPDATE_CHECK_FILE"
}

# Function to checkout a specific release tag
checkout_release() {
    local tag="$1"

    if [ -z "$tag" ]; then
        echo -e "${RED}Error: No tag specified${NC}"
        return 1
    fi

    if [ ! -d "$TJBOT_REPO/.git" ]; then
        echo -e "${RED}Error: TJBot repository not found at $TJBOT_REPO${NC}"
        return 1
    fi

    echo -e "${YELLOW}Fetching release tag $tag from GitHub...${NC}"
    if ! git -C "$TJBOT_REPO" fetch origin "tag:$tag" 2>&1; then
        echo -e "${RED}Error: Failed to fetch tag $tag${NC}"
        return 1
    fi

    echo -e "${YELLOW}Checking out release $tag...${NC}"
    if ! git -C "$TJBOT_REPO" checkout "tags/$tag" 2>&1; then
        echo -e "${RED}Error: Failed to checkout tag $tag${NC}"
        return 1
    fi

    echo -e "${GREEN}Successfully updated to $tag${NC}"
    update_last_check_timestamp
    return 0
}

# Function to offer update to user
offer_update() {
    local current_version="$1"
    local latest_version="$2"

    echo -e "${YELLOW}A new version of TJBot is available!${NC}"
    echo "Current version: $current_version"
    echo "Latest version:  $latest_version"
    echo ""

    read -p "Would you like to update now? (y/n) " -n 1 -r
    echo

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        if checkout_release "$latest_version"; then
            echo ""
            echo -e "${GREEN}TJBot has been updated successfully!${NC}"
            read -p "Restart tjbot now? (y/n) " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                # Re-execute tjbot to load the updated version
                exec "$0" "$@"
            fi
        fi
    else
        echo "Update deferred. You can update manually with: tjbot update"
        update_last_check_timestamp
    fi
}

# Function to check for updates (non-blocking, runs in background)
check_update_auto() {
    if ! should_check_for_updates; then
        return
    fi

    # Run in subshell to avoid blocking
    (
        local current_version
        local latest_version

        current_version=$(get_current_version)
        latest_version=$(check_latest_release)

        # Only proceed if we got valid versions
        if [ -z "$latest_version" ] || [ "$current_version" = "$latest_version" ]; then
            update_last_check_timestamp
            return
        fi

        # Offer the update to the user
        offer_update "$current_version" "$latest_version"
    ) &

    # Don't wait for background process
    disown 2>/dev/null || true
}

# Function to perform manual update
do_update() {
    local target_tag="$1"
    local latest_version

    if [ -z "$target_tag" ]; then
        # No tag specified, get latest
        echo -e "${BLUE}Checking for latest release...${NC}"
        latest_version=$(check_latest_release)

        if [ -z "$latest_version" ]; then
            echo -e "${RED}Error: Could not check for latest release${NC}"
            echo "Please check your internet connection and try again."
            exit 1
        fi

        target_tag="$latest_version"
    fi

    local current_version
    current_version=$(get_current_version)

    echo "Current version: $current_version"
    echo "Target version:  $target_tag"
    echo ""

    if checkout_release "$target_tag"; then
        echo ""
        echo -e "${GREEN}TJBot has been updated successfully!${NC}"
    else
        exit 1
    fi
}

# Validate that a directory matches the new recipe contract
validate_recipe_dir() {
    local recipe_dir="$1"

    if [ ! -d "$recipe_dir" ]; then
        echo -e "${RED}Error: Recipe directory not found: $recipe_dir${NC}"
        return 1
    fi

    if [ ! -f "$recipe_dir/recipe.toml" ]; then
        echo -e "${RED}Error: Missing recipe.toml in $recipe_dir${NC}"
        return 1
    fi

    if [ ! -f "$recipe_dir/mise.toml" ]; then
        echo -e "${RED}Error: Missing mise.toml in $recipe_dir${NC}"
        return 1
    fi

    if ! grep -q "\[tasks\.start\]" "$recipe_dir/mise.toml"; then
        echo -e "${RED}Error: Missing [tasks.start] in $recipe_dir/mise.toml${NC}"
        return 1
    fi

    return 0
}

# Prompt helper for y/n capability flags
prompt_yes_no() {
    local prompt_text="$1"
    local default_value="$2"
    local reply

    read -r -p "$prompt_text" reply
    reply="${reply:-$default_value}"

    if [[ "$reply" =~ ^[Yy]$ ]]; then
        echo "true"
    else
        echo "false"
    fi
}

# Function to list recipes
list_recipes() {
    echo -e "${BLUE}Available TJBot Recipes:${NC}"
    echo ""

    if [ ! -d "$TJBOT_ROOT/recipes" ]; then
        echo -e "${RED}Error: recipes directory not found${NC}"
        exit 1
    fi

    for recipe_dir in "$TJBOT_ROOT/recipes"/*; do
        if [ -d "$recipe_dir" ]; then
            recipe_name=$(basename "$recipe_dir")

            if [ -f "$recipe_dir/recipe.toml" ] && [ -f "$recipe_dir/mise.toml" ]; then
                recipe_type="${GREEN}[Standard]${NC}"
            else
                recipe_type="${RED}[Invalid]${NC}"
            fi

            echo -e "  - $recipe_name $recipe_type"
        fi
    done
    echo ""
    echo "Run a recipe with: tjbot run <recipe>"
}

# Function to generate recipe.toml
write_recipe_toml() {
    local recipe_dir="$1"
    local recipe_name="$2"
    local description="$3"
    local author="$4"
    local license="$5"

    cat > "$recipe_dir/recipe.toml" << EOF
[recipe]
name = "$recipe_name"
description = "$description"
version = "1.0.0"
author = "$author"
license = "$license"

# Recipe-specific configuration
[config]
EOF
}

# Function to generate mise.toml
write_mise_toml() {
    local recipe_dir="$1"
    local language="$2"

    if [ "$language" = "javascript" ]; then
        cat > "$recipe_dir/mise.toml" << 'EOF'
[tools]
node = ">=18"

[tasks.start]
run = "npm start"
description = "Run recipe"
EOF
    else
        cat > "$recipe_dir/mise.toml" << 'EOF'
[tools]
python = "3.11"

[tasks.start]
run = "uv run main.py"
description = "Run recipe"
EOF
    fi
}

# Function to generate README.md
write_recipe_readme() {
    local recipe_dir="$1"
    local recipe_name="$2"
    local description="$3"
    local recipe_slug="$4"
    local license="$5"
    local listen="$6"
    local see="$7"
    local shine="$8"
    local speak="$9"
    local wave="${10}"

# shellcheck disable=SC2006
    cat > "$recipe_dir/README.md" << EOF
# $recipe_name

TODO: Add description here

## Requirements

- Raspberry Pi
- TJBot configured (\`tjbot bootstrap\` + \`tjbot config\`)
- Required capabilities:
  - listen: $listen
  - see: $see
  - shine: $shine
  - speak: $speak
  - wave: $wave

## How It Works

This recipe uses TJBot capabilities listed above and runs through \`mise run start\`.

## Setup

Install tools and dependencies from this recipe directory.

\`\`\`sh
mise install
\`\`\`

## Run

Run from anywhere:

\`\`\`sh
tjbot run $recipe_slug
\`\`\`

Or from this recipe directory:

\`\`\`sh
tjbot run .
\`\`\`

## Customize

### Customization 1

Edit the recipe source code to change default behavior.

### Customization 2

Adjust runtime/dependency behavior through \`mise.toml\` and language project files.

## Troubleshoot

If you have problems running this recipe, see the TJBot troubleshooting guide.

## Contribute

If you would like to contribute to TJBot, see the contributor's guide.

## License

$license
EOF
}
# shellcheck enable=all

# Function to generate language starter files
write_language_starters() {
    local recipe_dir="$1"
    local recipe_name="$2"
    local description="$3"
    local author="$4"
    local license="$5"
    local language="$6"
    local listen="$7"
    local see="$8"
    local shine="$9"
    local speak="${10}"
    local wave="${11}"

    if [ "$language" = "javascript" ]; then
        # Build hardware config based on capabilities
        local hardware_lines=""
        [ "$listen" = "true" ] && hardware_lines+="        'microphone': true,\n"
        [ "$see" = "true" ] && hardware_lines+="        'camera': true,\n"
        [ "$shine" = "true" ] && hardware_lines+="        'led': true,\n"
        [ "$speak" = "true" ] && hardware_lines+="        'speaker': true,\n"
        [ "$wave" = "true" ] && hardware_lines+="        'servo': true,\n"
        
        # Remove trailing comma from last line
        hardware_lines=$(echo -e "$hardware_lines" | sed '$ s/,$//')

        cat > "$recipe_dir/index.js" << EOF
/**
 * $recipe_name
 * Author: $author
 */

import TJBot from 'tjbot';

const tj = new TJBot({
    hardware: {
${hardware_lines}
    }
});
EOF

        cat > "$recipe_dir/package.json" << EOF
{
  "name": "$recipe_name",
  "version": "1.0.0",
  "description": "$description",
  "license": "$license",
  "author": "$author",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "tjbot": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "globals": "^17.0.0"
  }
}
EOF
    else
        cat > "$recipe_dir/main.py" << 'EOF'
def main():
    print("Hello from TJBot recipe!")


if __name__ == "__main__":
    main()
EOF

        cat > "$recipe_dir/pyproject.toml" << EOF
[project]
name = "$recipe_slug"
version = "1.0.0"
description = "A TJBot recipe"
requires-python = ">=3.11"
dependencies = []

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
EOF
    fi
}

# Function to create a recipe scaffold
create_recipe() {
    local recipe_folder="$1"
    local recipe_name
    local description
    local author
    local license
    local language
    local recipe_dir
    local listen
    local see
    local shine
    local speak
    local wave

    if [ -z "$recipe_folder" ]; then
        echo -e "${RED}Error: Recipe name required${NC}"
        echo "Usage: tjbot create <recipe-name>"
        exit 1
    fi

    # Strip any directory prefix (e.g. "recipes/test-recipe" -> "test-recipe")
    recipe_folder="$(basename "$recipe_folder")"
    recipe_dir="$TJBOT_ROOT/recipes/$recipe_folder"
    if [ -e "$recipe_dir" ]; then
        echo -e "${RED}Error: Recipe already exists at $recipe_dir${NC}"
        exit 1
    fi

    echo -e "${BLUE}Create TJBot recipe${NC}"
    echo ""

    read -r -p "Display name [$recipe_folder]: " recipe_name
    recipe_name="${recipe_name:-$recipe_folder}"

    read -r -p "Description: " description
    if [ -z "$description" ]; then
        description="TODO: Add description"
    fi

    read -r -p "Author [TJBot Contributor]: " author
    if [ -z "$author" ]; then
        author="TJBot Contributor"
    fi

    read -r -p "License [Apache-2.0]: " license
    if [ -z "$license" ]; then
        license="Apache-2.0"
    fi

    read -r -p "Language (python/py or javascript/js): " language
    case "$language" in
        javascript|js)
            language="javascript"
            ;;
        python|py)
            language="python"
            ;;
        *)
            echo -e "${RED}Error: Language must be 'python', 'py', 'javascript', or 'js'${NC}"
            exit 1
            ;;
    esac

    echo ""
    echo "Required capabilities:"
    listen=$(prompt_yes_no "- listen (microphone + STT) (y/n) [n]: " "n")
    see=$(prompt_yes_no "- see (camera + vision) (y/n) [n]: " "n")
    shine=$(prompt_yes_no "- shine (LED) (y/n) [n]: " "n")
    speak=$(prompt_yes_no "- speak (speaker + TTS) (y/n) [n]: " "n")
    wave=$(prompt_yes_no "- wave (servo) (y/n) [n]: " "n")

    mkdir -p "$recipe_dir"

    write_recipe_toml "$recipe_dir" "$recipe_name" "$description" "$author" "$license"
    write_mise_toml "$recipe_dir" "$language"
    write_language_starters "$recipe_dir" "$recipe_name" "$description" "$author" "$license" "$language" "$listen" "$see" "$shine" "$speak" "$wave"
    write_recipe_readme "$recipe_dir" "$recipe_name" "$description" "$recipe_folder" "$license" "$listen" "$see" "$shine" "$speak" "$wave"

    echo ""
    echo -e "${GREEN}Created recipe at: $recipe_dir${NC}"
}

# Function to run a recipe
run_recipe() {
    local recipe_name="$1"
    local recipe_dir

    if [ "$recipe_name" = "." ]; then
        recipe_dir="$PWD"
        recipe_name="current directory"
    else
        recipe_dir="$TJBOT_ROOT/recipes/$recipe_name"
    fi

    if ! validate_recipe_dir "$recipe_dir"; then
        if [ "$recipe_name" != "current directory" ]; then
            echo ""
            echo "Available recipes:"
            list_recipes
        fi
        exit 1
    fi

    if ! command -v mise &> /dev/null; then
        echo -e "${RED}Error: mise is not installed${NC}"
        echo ""
        echo "Install mise with:"
        echo "  curl https://mise.run | sh"
        exit 1
    fi

    echo -e "${GREEN}Running recipe: $recipe_name${NC}"
    cd "$recipe_dir" || exit 1
    mise run start
}

# Main command routing
case "$1" in
    bootstrap)
        echo -e "${GREEN}Running TJBot bootstrap...${NC}"
        cd "$TJBOT_ROOT/bootstrap" || exit 1
        exec "$SHELL" ./bootstrap.sh
        ;;

    config)
        shift
        cd "$TJBOT_ROOT/config" || exit 1

        # Check if uv is installed
        if ! command -v uv &> /dev/null; then
            echo -e "${RED}Error: uv is not installed${NC}"
            echo ""
            echo "Install uv with:"
            echo "  curl -LsSf https://astral.sh/uv/install.sh | sh"
            exit 1
        fi

        exec uv run config.py "$@"
        ;;

    run)
        if [ -z "$2" ]; then
            list_recipes
        else
            run_recipe "$2"
        fi
        ;;

    create)
        create_recipe "$2"
        ;;

    update)
        do_update "$2"
        ;;

    check-updates)
        echo -e "${BLUE}Checking for TJBot updates...${NC}"
        current_version=$(get_current_version)
        latest_version=$(check_latest_release)

        if [ -z "$latest_version" ]; then
            echo -e "${RED}Error: Could not check for latest release${NC}"
            echo "Please check your internet connection and try again."
            exit 1
        fi

        echo "Current version: $current_version"
        echo "Latest version:  $latest_version"
        echo ""

        if [ "$current_version" = "$latest_version" ]; then
            echo -e "${GREEN}You are already running the latest version!${NC}"
        else
            echo -e "${YELLOW}A new version is available.${NC}"
            read -p "Would you like to update? (y/n) " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                do_update "$latest_version"
            fi
        fi
        ;;

    "")
        show_usage
        ;;

    *)
        echo -e "${RED}Error: Unknown command '$1'${NC}"
        echo ""
        show_usage
        exit 1
        ;;
esac
