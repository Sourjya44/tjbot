shopt -s expand_aliases

# ============================================================================
# Setup ANSI color codes for pretty output, but only if we're running in a
# terminal
# ============================================================================
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ] && [ "${TERM:-dumb}" != "dumb" ]; then
    ANSI_RESET=$'\033[0m'
    ANSI_BOLD=$'\033[1m'
    ANSI_DIM=$'\033[2m'
    ANSI_CYAN=$'\033[36m'
    ANSI_GREEN=$'\033[32m'
    ANSI_YELLOW=$'\033[33m'
    ANSI_RED=$'\033[31m'
    ANSI_BLUE=$'\033[34m'
    ANSI_MAGENTA=$'\033[35m'
else
    ANSI_RESET=""
    ANSI_BOLD=""
    ANSI_DIM=""
    ANSI_CYAN=""
    ANSI_GREEN=""
    ANSI_YELLOW=""
    ANSI_RED=""
    ANSI_BLUE=""
    ANSI_MAGENTA=""
fi

export ANSI_RESET ANSI_BOLD ANSI_DIM ANSI_CYAN ANSI_GREEN ANSI_YELLOW ANSI_RED ANSI_BLUE ANSI_MAGENTA

# ============================================================================
# Helper functions
# ============================================================================
setup_echo() {
    if [ "$#" -eq 0 ]; then
        builtin printf '\n'
        return
    fi

    builtin printf '%b%s%b\n' "${ANSI_CYAN}" "$*" "${ANSI_RESET}"
}

alias echo='setup_echo'

setup_section() {
    local label="$1"
    local display_label="${label//-/ }"
    local width=80
    local text=" ${display_label} "
    local text_length=${#text}
    local remaining=$((width - text_length))
    local left_padding=0
    local right_padding=0

    if [ "$remaining" -gt 0 ]; then
        left_padding=$((remaining / 2))
        right_padding=$((remaining - left_padding))
    fi

    printf '%b' "${ANSI_BOLD}${ANSI_MAGENTA}"
    printf '%*s' "$left_padding" '' | tr ' ' '-'
    printf '%s' "$text"
    printf '%*s%b\n' "$right_padding" '' "${ANSI_RESET}" | tr ' ' '-'
}

setup_command() {
    printf '%b→ %s%b\n' "${ANSI_BOLD}${ANSI_CYAN}" "$*" "${ANSI_RESET}"
}

setup_stream() {
    local color="$1"
    local prefix="$2"
    local line

    while IFS= read -r line || [ -n "$line" ]; do
        printf '%b%s%b %s\n' "$color" "$prefix" "${ANSI_RESET}" "$line"
    done
}

export -f setup_stream

run_logged_cmd() {
    local label="$1"
    shift

    setup_command "$label"
    "$@" > >(setup_stream "${ANSI_DIM}${ANSI_GREEN}" "  |") 2> >(setup_stream "${ANSI_DIM}${ANSI_RED}" "  !")
}

command_exists() {
    local user="$1"
    local cmd="$2"
    sudo -H -u "$user" sh -lc "command -v $cmd" >/dev/null 2>&1
}

# Run a command as target user, ensuring uv is available in that shell.
run_with_uv() {
    local user="$1"
    shift
    sudo -H -u "$user" sh -lc '
        if ! command -v uv >/dev/null 2>&1 && [ -f "$HOME/.local/bin/env" ]; then
            . "$HOME/.local/bin/env" >/dev/null 2>&1
        fi
        UV_CMD=$(command -v uv 2>/dev/null || true)
        [ -n "$UV_CMD" ] || exit 127
        "$@"
    ' sh "$@"
}

# ============================================================================
# Setup completion artwork!
# ============================================================================
render_completion_art() {
    local sleep_time="$1"
    local color_mode="${2:-none}"
    local art_color=""
    local i=0
    local line
    local -a rainbow_colors=(
        "${ANSI_RED}"
        "${ANSI_YELLOW}"
        "${ANSI_GREEN}"
        "${ANSI_CYAN}"
        "${ANSI_BLUE}"
        "${ANSI_MAGENTA}"
    )
    local -a lines=(
        ""
        ""
        "                           .yNNs\`                           "
        "                           :hhhh-                           "
        "/ssssssssssssssssssssssssssssssssssssssssssssssssssssssssss+"
        "yNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNy"
        "yMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMNmmmNMMMMMMMMMMMMMMMMMMMMMMNmmmMMMMMMMMMMMMMMy"
        "yMMMMMMMMMMMNd/\`\`\`.+NNMMMMMMMMMMMMMMMMNm+.\` \`/dNMMMMMMMMMMMy"
        "yMMMMMMMMMMMNo     \`hMMMMMMMMMMMMMMMMMMy\`     oNMMMMMMMMMMMy"
        "yMMMMMMMMMMMNm+.\`\`-sNMMMMMMMMMMMMMMMMMNNs-\`\`.+mNMMMMMMMMMMMy"
        "yMMMMMMMMMMMMMMNmmMMMMMMMMMMMMMMMMMMMMMMMMmmNMMMMMMMMMMMMMMy"
        "yNNNNNMMMMMMMMMMMMNNNNNNMMNNNNNNNNNNMMMMMMMMMMMMMMMMMMMNNNMy"
        "-::::::::::::::::::::::::::::::::::::::::::::::::::::::::::-"
        "                                                            "
        "                     \`\`\`\`\`\`\`....--::::////++++ooossyyhhhhh/"
        "//++ossssssyyyyhhddmmmmmmmmmmmmNNNNNMMNNNNNNMMMMMMMMMMMMMNNo"
        "dMNMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMy"
        "sMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMd"
        "oNMMMMMMMMMMMMMMMMNNNNNNNNMMMMMMNNNNNmmmmmmmmmddhhhhyyyyssss"
        "+Nmmmddhhhhyyyyssoo++++/////:::---....\`\`\`\`\`\`\`\`        "
        ""
        "-------------------------------------------------------------------"
    )

    case "$color_mode" in
        red) art_color="${ANSI_RED}" ;;
        yellow) art_color="${ANSI_YELLOW}" ;;
        green) art_color="${ANSI_GREEN}" ;;
        cyan) art_color="${ANSI_CYAN}" ;;
        blue) art_color="${ANSI_BLUE}" ;;
        magenta) art_color="${ANSI_MAGENTA}" ;;
        rainbow) art_color="" ;;
        *) art_color="" ;;
    esac

    for line in "${lines[@]}"; do
        if [ "$color_mode" = "rainbow" ]; then
            builtin printf '%b%s%b\n' "${rainbow_colors[$((i % ${#rainbow_colors[@]}))]}" "$line" "${ANSI_RESET}"
            i=$((i + 1))
        else
            builtin printf '%b%s%b\n' "$art_color" "$line" "${ANSI_RESET}"
        fi
        sleep "$sleep_time"
    done
}

# ============================================================================
# Make sure this script is run as root
# ============================================================================
user=$(id -u)
if [ "$user" -ne 0 ]; then
    echo "This script requires root permissions. Please run this script with sudo."
    exit
fi

# ============================================================================
# ASCII art!
# ============================================================================
echo "  _   _ _           _                                        "
echo " | | (_) |         | |  _                                    "
echo " | |_ _| |__   ___ | |_(_)                                   "
echo " | __| | '_ \ / _ \| __|                                     "
echo " | |_| | |_) | (_) | |_ _                                    "
echo "  \__| |_.__/ \___/ \__(_)                  _ _              "
echo "    _/ |                                   (_) |             "
echo "   |__/___  _ __ ___  _ __ ___  _   _ _ __  _| |_ _   _      "
echo "  / __/ _ \| '_ ' _ \| '_ ' _ \| | | | '_ \| | __| | | |     "
echo " | (_| (_) | | | | | | | | | | | |_| | | | | | |_| |_| |     "
echo "  \___\___/|_| |_| |_|_| |_| |_|\__,_|_| |_|_|\__|\__, |     "
echo "          | (_) | (_)                       | |    __/ |     "
echo "   ___  __| |_| |_ _  ___  _ __     ___  ___| |_ _|___/_ __  "
echo "  / _ \/ _' | | __| |/ _ \| '_ \   / __|/ _ \ __| | | | '_ \ "
echo " |  __/ (_| | | |_| | (_) | | | |  \__ \  __/ |_| |_| | |_) |"
echo "  \___|\__,_|_|\__|_|\___/|_| |_|  |___/\___|\__|\__,_| .__/ "
echo "                                                      | |    "
echo "                                                      |_|    "

# ============================================================================
# Intro message
# ============================================================================
echo ""
echo "-----------------------------------------------------------------------"
echo "Welcome! Let's set up your Raspberry Pi with the TJBot software."
echo ""
echo "Important: This script was designed for setting up a Raspberry Pi after"
echo "a clean install of Raspbian. If you are running this script on a"
echo "Raspberry Pi that you've used for other projects, please take a look at"
echo "what this script does BEFORE running it to ensure you are comfortable"
echo "with its actions."
echo "-----------------------------------------------------------------------"

# ============================================================================
# Confirm running setup
# ============================================================================
read -r -p "Would you like to use this Raspberry Pi for TJBot? [Y/n] " choice </dev/tty
case "$choice" in
    "n" | "N")
        echo "Cancelling TJBot software installation."
        exit
        ;;
    *) ;;
esac
echo

# ============================================================================
# Test CPU architecture
#   ARMv6 is not supported (RPi 1, Pi Zero, Compute Module 1)
# ============================================================================
setup_section "pre-install checks"

CPUARCH=$(lscpu | grep Arch | cut -d ':' -f2 | awk '{$1=$1};1')
if [ "$CPUARCH" = 'armv6l' ];
   then
      echo "🛑 ARMv6 is not supported for TJBot due to software availability"
      echo "on this processor architecture. Please use another Raspberry Pi model."
      exit 1
else
   echo "✓ $CPUARCH processor architecture supported."
fi

# ============================================================================
# Test Raspbian version
#   Raspbian 12 (Bookworm) or later is required
# ============================================================================
RASPBIAN_VERSION_ID=$(grep '^VERSION_ID=' /etc/os-release | cut -d '"' -f 2)
RASPBIAN_CODENAME=$(grep '^VERSION_CODENAME=' /etc/os-release | cut -d '=' -f 2)
if [ "$RASPBIAN_VERSION_ID" -lt 12 ]; then
    echo "⚠️ It looks like your Raspberry Pi is running an older version"
    echo "of Raspian. TJBot requires Raspian 12 (Bookworm) or later."
    echo ""
    read -r -p "Would you like to continue with setup? [Y/n] " choice </dev/tty
    case "$choice" in
        "n" | "N")
            echo "Cancelling TJBot software installation."
            exit
            ;;
        *) ;;
    esac
else
   echo "✓ Raspian OS level supported: $RASPBIAN_VERSION_ID ($RASPBIAN_CODENAME)."
fi

# ============================================================================
# Install additional apt packages
# ============================================================================
setup_section "install additional apt packages"

PACKAGES=(
    libgpiod-dev
    liblgpio-dev
    rpicam-apps-lite
)

run_logged_cmd "apt-get update" apt-get update
run_logged_cmd "apt-get install -y ${PACKAGES[*]}" apt-get install -y "${PACKAGES[@]}"

# ============================================================================
# Capture target user and home directory
# ============================================================================
TARGET_USER=${SUDO_USER:-$USER}
TARGET_HOME=$(getent passwd "$TARGET_USER" | cut -d: -f6)
TJBOT_DIR="$TARGET_HOME/.tjbot/tjbot"

# ============================================================================
# Install mise
# ============================================================================
setup_section "install mise"
echo "Installing mise..."

if ! command_exists "$TARGET_USER" "mise"; then
    echo "Installing mise for user $TARGET_USER..."
    run_logged_cmd "install mise" sudo -u "$TARGET_USER" sh -lc 'curl -sLSf https://mise.run | sh'
    echo "✓ mise installed successfully"
else
    echo "✓ mise is already installed for $TARGET_USER"
fi

# ============================================================================
# Install uv
# ============================================================================
setup_section "install uv"
echo "Installing uv..."

if ! command_exists "$TARGET_USER" "uv"; then
    echo "Installing uv for user $TARGET_USER..."
    run_logged_cmd "install uv" sudo -H -u "$TARGET_USER" sh -lc 'curl -sLSf https://astral.sh/uv/install.sh | sh'
fi

# Best-effort status check for uv availability in target user's shell.
if run_with_uv "$TARGET_USER" uv --version >/dev/null 2>&1; then
    echo "✓ uv is available"
else
    echo "🛑 Failed to locate uv command for $TARGET_USER, please check your uv installation"
    exit 1
fi

# ============================================================================
# Install Node.js
# ============================================================================
setup_section "install node.js"
echo "Installing Node.js..."

# Get the first version in the list where the 10th column (LTS) is not "-"
LATEST_NODE_LTS_VERSION=$(curl -sLSf https://nodejs.org/download/release/index.tab | \
  awk '($10 != "-" && NR != 1) { print $1; exit }' | cut -d '.' -f 1 | cut -d 'v' -f 2)
MIN_NODE_MAJOR="20"
NEED_NODE_INSTALL=false

if command_exists "$TARGET_USER" "node"; then
    NODE_VERSION=$(node --version 2>&1)
    NODE_MAJOR=$(node --version 2>&1 | cut -d '.' -f 1 | cut -d 'v' -f 2)
    if [ "$NODE_MAJOR" -lt "$MIN_NODE_MAJOR" ]; then
        echo "⚠️ Node.js $NODE_VERSION is currently installed. TJBot requires"
        echo "v$MIN_NODE_MAJOR.x or later."

        read -r -p "Would you like to update Node.js to $LATEST_NODE_LTS_VERSION? [Y/n] " choice </dev/tty
        case "$choice" in
            "" | "y" | "Y")
                NEED_NODE_INSTALL=true
                ;;
            *)
                echo "⚠️ TJBot recipes that require Javascript may not run properly with Node.js $NODE_VERSION."
                ;;
        esac
    else
        echo "✓ Node.js version $NODE_VERSION is installed."
    fi
else
    echo "Node.js is not installed."
    NEED_NODE_INSTALL=true
fi

if $NEED_NODE_INSTALL; then
    run_logged_cmd "configure NodeSource repository" bash -lc "curl -sLSf https://deb.nodesource.com/setup_${LATEST_NODE_LTS_VERSION}.x | sudo -E bash -"
    run_logged_cmd "apt install nodejs -y" apt install nodejs -y
fi

# ============================================================================
# Clone TJBot repository
# ============================================================================
setup_section "clone TJBot repository"

if [ ! -d "$TJBOT_DIR" ]; then
    echo "Cloning TJBot project to $TJBOT_DIR"
    run_logged_cmd "git clone tjbot" sudo -u "$TARGET_USER" git clone https://github.com/tjbot-ce/tjbot.git "$TJBOT_DIR"
else
    echo "TJBot project already exists in $TJBOT_DIR, pulling latest changes"
    run_logged_cmd "git pull tjbot" sudo -u "$TARGET_USER" git -C "$TJBOT_DIR" pull
fi

echo "Initializing TJBot submodules"
run_logged_cmd "git submodule update" sudo -u "$TARGET_USER" git -C "$TJBOT_DIR" submodule update --init --recursive

# ============================================================================
# Add tjbot/bin to $PATH
# ============================================================================
setup_section "add TJBot to \$PATH [in ~/.profile]"

PROFILE_FILE="$TARGET_HOME/.profile"
if ! grep -Fq "$TJBOT_DIR/bin" "$PROFILE_FILE" 2>/dev/null; then
    echo "Adding $TJBOT_DIR/bin to $TARGET_USER PATH in $PROFILE_FILE"
    touch "$PROFILE_FILE"
    printf "\n# Added by TJBot setup\nexport PATH=\"\$PATH:%s/bin\"\n" "$TJBOT_DIR" >> "$PROFILE_FILE"
    chown "$TARGET_USER":"$TARGET_USER" "$PROFILE_FILE" 2>/dev/null || true
fi

# ============================================================================
# RPi 3: blacklist audio kernel modules
# ============================================================================
RPI_MODEL=$(grep "^Model" /proc/cpuinfo | cut -d ':' -f2 | xargs)
if [[ "$RPI_MODEL" == *"Raspberry Pi 3"* ]]; then
    setup_section "[RPi 3] blacklist kernel audio modules"
    echo "On Raspberry Pi 3 models, there is a known conflict between the LED "
    echo "and the built-in audio jack. In order for the LED to work, we need to"
    echo "disable certain kernel modules to avoid this conflict. If you have "
    echo "plugged in a speaker via HDMI, USB, or Bluetooth, this is a safe "
    echo "operation and you will be able to play sound and use the LED at the "
    echo "same time. If you plan to use the built-in audio jack, we recommend "
    echo "NOT disabling the sound kernel modules."
    read -r -p "Enable or disable sound kernel modules? [DISABLE/enable] " choice </dev/tty
    case "$choice" in
        "" | "d" | "D" | "disable" | "DISABLE")
            echo "Disabling the kernel modules for the built-in audio jack."
            cat > "/etc/modprobe.d/tjbot-blacklist-snd.conf" << EOF
blacklist snd_bcm2835
EOF
            ;;
        "e" | "E" | "enable" | "ENABLE")
            if [ -f /etc/modprobe.d/tjbot-blacklist-snd.conf ]; then
                echo "Enabling the kernel modules for the built-in audio jack."
                rm /etc/modprobe.d/tjbot-blacklist-snd.conf
            fi
            ;;
        *)
            echo "No changes will be made to the sound kernel modules. If you want to enable"
            echo "or disable them, you can run this script again and choose the appropriate"
            echo "option."
        ;;
    esac
fi

# ============================================================================
# Create tjbot.toml configuration file
# ============================================================================
setup_section "configure TJBot"
echo "Configuring TJBot hardware & software settings..."

cd "$TJBOT_DIR/config" || (echo "🛑 Failed to locate directory $TJBOT_DIR/config, please check your tjbot installation" && exit 1)
run_logged_cmd "uv sync --quiet" run_with_uv "$TARGET_USER" uv sync --quiet || (echo "🛑 Failed to sync dependencies for tjbot config tool, please check your tjbot installation and uv setup" && exit 1)
if [ ! -f "$TARGET_HOME/.tjbot/tjbot.toml" ]; then
    run_logged_cmd "uv run config init" run_with_uv "$TARGET_USER" uv run config init || (echo "🛑 Failed to create default tjbot config, please check your tjbot installation and uv setup" && exit 1)
fi

# ============================================================================
# Installation complete!
# ============================================================================
render_completion_art 0.05 rainbow

# ============================================================================
# Reboot
# ============================================================================
setup_section "setup complete"
echo "Setup complete. Your Raspberry Pi is now set up as a TJBot! 🤖"
read -r -p "We recommend rebooting for all changes to take effect. Reboot? [Y/n] " choice </dev/tty
case "$choice" in
    "" | "y" | "Y")
        echo "Rebooting."
        reboot
        ;;
    *)
        echo "Please reboot your Raspberry Pi for all changes to take effect."
        ;;
esac
